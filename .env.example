# ===========================================
# Area 862 System - Variables de Entorno
# ===========================================
# Copia este archivo a .env y configura los valores
# cp .env.example .env

# ===========================================
# BASE DE DATOS (Obligatorio)
# ===========================================
# URL de conexion a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_db

# Para PostgreSQL local en Ubuntu:
DATABASE_URL=postgresql://area862:tu_password_seguro@localhost:5432/area862

# Para AWS RDS o base de datos externa:
# DATABASE_URL=postgresql://usuario:password@tu-host.com:5432/area862

# Forzar SSL en la conexion a la base de datos
# Solo necesario si usas un proveedor externo como Heroku, Render, etc.
# Para PostgreSQL local en Ubuntu, dejalo comentado
# DATABASE_SSL=true

# ===========================================
# SEGURIDAD (Obligatorio en produccion)
# ===========================================
# Secreto para firmar las sesiones (minimo 32 caracteres aleatorios)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=genera_un_secreto_aleatorio_de_32_caracteres_minimo

# Entorno de ejecucion
# Opciones: development, production
NODE_ENV=production

# ===========================================
# SERVIDOR (Obligatorio)
# ===========================================
# Puerto del servidor (default: 5000)
PORT=5000

# Dominio del servidor (sin https://)
# Usado para configurar CORS y cookies
SERVER_DOMAIN=mapas.iprintpos.com

# ===========================================
# GOOGLE MAPS (Obligatorio)
# ===========================================
# API Key de Google Maps (para frontend - mapas en la web)
# Obtener en: https://console.cloud.google.com/apis/credentials
# APIs que debes habilitar: Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps

# API Key de Google Maps (para backend - correccion de direcciones)
# Puede ser la misma key que VITE_GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps

# ===========================================
# APLICACIONES MOVILES (Solo para compilar apps)
# ===========================================
# URL completa del API para las apps moviles (con https://)
VITE_API_URL=https://mapas.iprintpos.com

# ===========================================
# RESPOND.IO (Opcional)
# ===========================================
# El token de Respond.io se configura desde la interfaz web
# en Mensajeria > Configuracion > API Token
# No es necesario configurarlo aqui
