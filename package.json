{
  "name": "area862system",
  "version": "1.0.0",
  "description": "Area 862 System - Sistema de Logistica de Entregas",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "vite build",
    "build:copy-assets": "node -e \"const fs=require('fs');const path=require('path');['png','svg'].forEach(ext=>{fs.readdirSync('public').filter(f=>f.endsWith('.'+ext)).forEach(f=>fs.copyFileSync(path.join('public',f),path.join('dist',f)))});\"",
    "build:mobile": "npm run build && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@googlemaps/js-api-loader": "^1.16.10",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "sequelize": "^6.37.7",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21"
  }
}
