# HormiRuta Environment Variables

# Google Maps API Key (also needed in Android strings.xml for native app)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API URL (required for mobile app, optional for web)
# For mobile app, set this to your deployed backend URL
# Example: https://your-app.replit.app:8000
VITE_API_URL=
